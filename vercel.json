{
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "profitslab.io" }],
      "destination": "https://www.profitslab.io/:path*",
      "permanent": true
    },
    {
      "source": "/thank-you.html",
      "destination": "/ai-shortcut-stack/thank-you",
      "permanent": true
    },
    {
      "source": "/ai-shortcut-stack/thank-you.html",
      "destination": "/ai-shortcut-stack/thank-you",
      "permanent": true
    }
  ]
}
