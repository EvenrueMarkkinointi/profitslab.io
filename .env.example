# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (used in outbound links in the GHL email)
NEXT_PUBLIC_SITE_URL=https://profitslab.io

# GHL (GoHighLevel) — inbound webhook URL that triggers the report-delivery workflow
# Payload: { email, report_url, total_score, tier }
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_WORKFLOW_ID/sandbox
